{
  "tabWidth": 2,
  "arrowParens": "always",
  "singleQuote": true,
  "trailingComma": "all",
  "endOfLine": "auto",
  "printWidth": 120,
  "semi": true,
  "bracketSpacing": true,
  "jsxBracketSameLine": true,
  "useTabs": false,
  "quoteProps": "consistent",
  "jsxSingleQuote": true,
  "bracketSameLine": true,
  "singleAttributePerLine": true,
  "plugins": ["prettier-plugin-tailwindcss"]
}
